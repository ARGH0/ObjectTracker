<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ObjectTracker.UI.Desktop.MainWindow"
        Title="ObjectTracker - Background Estimation Lab"
        Width="1460"
        Height="900"
        MinWidth="1080"
        MinHeight="680"
        Background="#0E1418"
        d:DesignWidth="1460"
        d:DesignHeight="900">
    <Grid RowDefinitions="Auto,*,14,190" Margin="20">
        <Border Grid.Row="0"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,16"
                BorderThickness="1"
                BorderBrush="#3C4E57">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#1A2C36" />
                    <GradientStop Offset="1" Color="#2D4251" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="Background Estimation Lab"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#F2FBFF" />
                    <TextBlock Text="Fresh baseline: loop through videos and extract moving foreground using estimated static background."
                               Foreground="#B8D1DA"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Column="1"
                        VerticalAlignment="Center"
                        CornerRadius="999"
                        Padding="12,6"
                        Background="#21323B"
                        BorderThickness="1"
                        BorderBrush="#557282">
                    <TextBlock x:Name="RunStateBadge"
                               Text="Idle"
                               Foreground="#E3F6FF"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="340,20,*">
            <Border Grid.Column="0"
                    CornerRadius="14"
                    Padding="14"
                    BorderThickness="1"
                    BorderBrush="#324650"
                    Background="#111C22">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">
                    <TextBlock Text="Cameras"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#E8F8FF" />

                    <TextBlock Grid.Row="1"
                               x:Name="PlaylistCountText"
                               Text="0 cameras"
                               Foreground="#A1BDC9" />

                    <ListBox Grid.Row="3"
                             x:Name="PlaylistListBox"
                             MinHeight="260"
                             BorderBrush="#3B5866"
                             BorderThickness="1" />

                    <Grid Grid.Row="4" ColumnDefinitions="*,8,*">
                        <Button x:Name="AddVideosButton"
                                Grid.Column="0"
                                Content="Add Mock Cameras"
                                Height="38" />
                        <Button x:Name="RemoveSelectedButton"
                                Grid.Column="2"
                                Content="Remove Camera"
                                Height="38" />
                    </Grid>

                        <Grid Grid.Row="5" ColumnDefinitions="*,8,*,8,*">
                        <Button x:Name="ClearPlaylistButton"
                            Grid.Column="0"
                            Content="Clear Cameras"
                            Height="36" />
                        <Button x:Name="PreviousVideoButton"
                            Grid.Column="2"
                            Content="Previous"
                            Height="36" />
                        <Button x:Name="NextVideoButton"
                            Grid.Column="4"
                            Content="Next"
                            Height="36" />
                        </Grid>

                    <StackPanel Grid.Row="6" Spacing="8" Margin="0,8,0,0">
                        <CheckBox x:Name="LoopPlaylistCheckBox"
                                  Content="Loop camera videos"
                                  IsChecked="True" />

                        <Grid ColumnDefinitions="Auto,8,*">
                            <TextBlock Grid.Column="0"
                                       Text="Samples"
                                       VerticalAlignment="Center"
                                       Foreground="#C8DEE8" />
                            <TextBox x:Name="SampleCountTextBox"
                                     Grid.Column="2"
                                     Text="20"
                                     Watermark="20"
                                     HorizontalAlignment="Stretch" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,8,*">
                            <TextBlock Grid.Column="0"
                                       Text="Threshold"
                                       VerticalAlignment="Center"
                                       Foreground="#C8DEE8" />
                            <TextBox x:Name="ThresholdTextBox"
                                     Grid.Column="2"
                                     Text="100"
                                     Watermark="100"
                                     HorizontalAlignment="Stretch" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,8,*">
                            <TextBlock Grid.Column="0"
                                       Text="Motion Area"
                                       VerticalAlignment="Center"
                                       Foreground="#C8DEE8" />
                            <TextBox x:Name="MotionAreaTextBox"
                                     Grid.Column="2"
                                     Text="220"
                                     Watermark="220"
                                     HorizontalAlignment="Stretch" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,8,*">
                            <TextBlock Grid.Column="0"
                                       Text="Color Pixels"
                                       VerticalAlignment="Center"
                                       Foreground="#C8DEE8" />
                            <TextBox x:Name="ColorMinPixelsTextBox"
                                     Grid.Column="2"
                                     Text="40"
                                     Watermark="40"
                                     HorizontalAlignment="Stretch" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,8,*">
                            <TextBlock Grid.Column="0"
                                       Text="Morph Kernel"
                                       VerticalAlignment="Center"
                                       Foreground="#C8DEE8" />
                            <TextBox x:Name="MorphKernelSizeTextBox"
                                     Grid.Column="2"
                                     Text="3"
                                     Watermark="3"
                                     HorizontalAlignment="Stretch" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,8,*">
                            <TextBlock Grid.Column="0"
                                       Text="Process Width"
                                       VerticalAlignment="Center"
                                       Foreground="#C8DEE8" />
                            <TextBox x:Name="ProcessWidthTextBox"
                                     Grid.Column="2"
                                     Text="640"
                                     Watermark="640"
                                     HorizontalAlignment="Stretch" />
                        </Grid>

                        <Button x:Name="StartStopButton"
                                Content="Start"
                                Height="44"
                                FontSize="16"
                                FontWeight="Bold" />

                        <Button x:Name="OpenBakedMaskButton"
                            Content="Open Baked Mask"
                            Height="36" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="14"
                    Padding="12"
                    BorderThickness="1"
                    BorderBrush="#2F4752"
                    Background="#0C1215">
                <Grid RowDefinitions="*,Auto,Auto">
                    <Border Grid.Row="0"
                            CornerRadius="10"
                            BorderThickness="1"
                            BorderBrush="#475F6D"
                            Background="#070A0C">
                        <Grid RowDefinitions="*,8,*" ColumnDefinitions="*,8,*" Margin="8">
                            <Border Grid.Row="0" Grid.Column="0" CornerRadius="8" BorderBrush="#3C5662" BorderThickness="1" Background="#05090B">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="1. Background Estimation"
                                               Margin="8,6,8,4"
                                               Foreground="#BFDCE8"
                                               FontWeight="SemiBold" />
                                    <Image Grid.Row="1" x:Name="PreviewBackgroundMaskImage" Stretch="Uniform" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" CornerRadius="8" BorderBrush="#3C5662" BorderThickness="1" Background="#05090B">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="2. Moving Objects (Color)"
                                               Margin="8,6,8,4"
                                               Foreground="#BFDCE8"
                                               FontWeight="SemiBold" />
                                    <Image Grid.Row="1" x:Name="PreviewMovingColorImage" Stretch="Uniform" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" CornerRadius="8" BorderBrush="#3C5662" BorderThickness="1" Background="#05090B">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="3. Color Detection on Motion"
                                               Margin="8,6,8,4"
                                               Foreground="#BFDCE8"
                                               FontWeight="SemiBold" />
                                    <Image Grid.Row="1" x:Name="PreviewColorDetectionImage" Stretch="Uniform" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="2" CornerRadius="8" BorderBrush="#3C5662" BorderThickness="1" Background="#05090B">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="4. Speed + Direction"
                                               Margin="8,6,8,4"
                                               Foreground="#BFDCE8"
                                               FontWeight="SemiBold" />
                                    <Image Grid.Row="1" x:Name="PreviewMotionImage" Stretch="Uniform" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="1"
                               x:Name="CurrentVideoText"
                               Text="Current camera/video: -"
                               Foreground="#D6EDF8"
                               FontWeight="SemiBold" />

                    <TextBlock Grid.Row="2"
                               x:Name="StatusText"
                               Text="Status: ready"
                               Foreground="#9DB8C6"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                CornerRadius="12"
                Padding="12"
                BorderThickness="1"
                BorderBrush="#334A55"
                Background="#0D171D">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Runtime Log"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#CFE8F2" />

                <ListBox Grid.Row="1"
                         x:Name="LogListBox"
                         BorderThickness="1"
                         BorderBrush="#3F5D6B"
                         Background="#081015"
                         FontFamily="Cascadia Mono"
                         FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</Window>
