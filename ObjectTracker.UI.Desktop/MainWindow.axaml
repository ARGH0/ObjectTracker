<wnd:AppWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wnd="using:FluentAvalonia.UI.Windowing"
        mc:Ignorable="d"
        x:Class="ObjectTracker.UI.Desktop.MainWindow"
        Title="ObjectTracker"
        Width="1920"
        Height="1080"
        MinWidth="1080"
        MinHeight="680"
        Background="{StaticResource AppBackgroundBrush}"
        d:DesignWidth="1920"
        d:DesignHeight="1080">
    <Grid RowDefinitions="40,*,Auto"
          Margin="10,0,10,10">

        <!-- Compact title bar / branding strip -->
        <Border Grid.Row="0"
                Background="Transparent"
                wnd:AppWindow.AllowInteractionInTitleBar="False">
            <DockPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="ObjectTracker"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="Background Estimation Lab"
                           FontSize="11"
                           Classes="muted"
                           Margin="10,1,0,0"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="340,6,*">
            <Border Grid.Column="0"
                    Classes="surface"
                    Padding="10">
                    <Grid RowDefinitions="Auto,8,Auto,8,*,8,Auto">
                    <TextBlock Grid.Row="0"
                               Text="Camera Sources"
                               Classes="sectionTitle" />

                    <ListBox Grid.Row="2"
                             x:Name="PlaylistListBox"
                             MinHeight="150"
                             MaxHeight="220" />

                      <Grid Grid.Row="4"
                          RowDefinitions="Auto,8,Auto,8,*">
                        <Grid Grid.Row="0"
                            ColumnDefinitions="*,6,*">
                            <Button x:Name="AddVideosButton"
                                    Grid.Column="0"
                                    Classes="primary"
                                    Content="Add Camera" />
                            <Button x:Name="RemoveSelectedButton"
                                    Grid.Column="2"
                                    Classes="destructive"
                                    Content="Remove" />
                        </Grid>

                        <Button Grid.Row="2"
                                x:Name="ClearPlaylistButton"
                                Classes="ghost"
                                Content="Clear Cameras" />

                        <Border Grid.Row="4"
                                Classes="surfaceAlt"
                                Padding="10">
                                <Grid RowDefinitions="Auto,6,*,8,Auto">
                                <StackPanel Grid.Row="0"
                                            Spacing="2">
                                    <TextBlock Text="Processing"
                                               Classes="sectionTitle" />
                                    <TextBlock Text="Compact runtime tuning for selected camera"
                                               Classes="muted"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="8">
                                        <CheckBox x:Name="LoopPlaylistCheckBox"
                                                  Content="Loop camera videos"
                                                  IsChecked="True" />

                                            <Grid ColumnDefinitions="*,8,*"
                                                RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
                                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                                <TextBlock Text="Samples"
                                                           Classes="eyebrow" />
                                                <TextBox x:Name="SampleCountTextBox"
                                                         Text="20"
                                                         Watermark="20" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                                <TextBlock Text="Bake Source"
                                                           Classes="eyebrow" />
                                                <ComboBox x:Name="BakeSourceComboBox"
                                                          SelectedIndex="0">
                                                    <ComboBoxItem Content="Samples from source" />
                                                    <ComboBoxItem Content="Image file" />
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Spacing="4">
                                                <TextBlock Text="Bake Image"
                                                           Classes="eyebrow" />
                                                <TextBox x:Name="BakeImagePathTextBox"
                                                         IsReadOnly="True"
                                                         Watermark="No image selected" />
                                                <Grid ColumnDefinitions="*,8,*">
                                                    <Button x:Name="SelectBakeImageButton"
                                                            Grid.Column="0"
                                                            Classes="ghost"
                                                            Content="Select Image" />
                                                    <Button x:Name="ClearBakeImageButton"
                                                            Grid.Column="2"
                                                            Classes="ghost"
                                                            Content="Clear Image" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Row="4" Grid.Column="0" Spacing="4">
                                                <TextBlock Text="Threshold"
                                                           Classes="eyebrow" />
                                                <TextBox x:Name="ThresholdTextBox"
                                                         Text="100"
                                                         Watermark="100" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="4" Grid.Column="2" Spacing="4">
                                                <TextBlock Text="Motion Area"
                                                           Classes="eyebrow" />
                                                <TextBox x:Name="MotionAreaTextBox"
                                                         Text="220"
                                                         Watermark="220" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="6" Grid.Column="0" Spacing="4">
                                                <TextBlock Text="Color Pixels"
                                                           Classes="eyebrow" />
                                                <TextBox x:Name="ColorMinPixelsTextBox"
                                                         Text="40"
                                                         Watermark="40" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="6" Grid.Column="2" Spacing="4">
                                                <TextBlock Text="Morph Kernel"
                                                           Classes="eyebrow" />
                                                <TextBox x:Name="MorphKernelSizeTextBox"
                                                         Text="3"
                                                         Watermark="3" />
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Process Width"
                                                       Classes="eyebrow" />
                                            <TextBox x:Name="ProcessWidthTextBox"
                                                     Text="640"
                                                     Watermark="640" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>

                                <Grid Grid.Row="4"
                                      ColumnDefinitions="*,8,*">
                                    <Button x:Name="StartStopButton"
                                            Grid.Column="0"
                                            Classes="primary"
                                            Content="Start"
                                            FontWeight="Bold" />
                                    <Button x:Name="OpenBakedMaskButton"
                                            Grid.Column="2"
                                            Classes="ghost"
                                            Content="Open Baked Mask" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <Border Grid.Column="2"
                    Classes="surface"
                    Padding="10">
                    <Grid RowDefinitions="Auto,8,*">
                    <Border Grid.Row="0"
                            Classes="surfaceAlt"
                            Padding="8">
                        <Grid ColumnDefinitions="*,8,*,Auto">
                            <TextBlock x:Name="CurrentVideoText"
                                       Grid.Column="0"
                                       Text="Current camera/source: -"
                                       VerticalAlignment="Center"
                                       Foreground="#E8F0F5"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />

                            <TextBlock x:Name="StatusText"
                                       Grid.Column="2"
                                       Text="Status: ready"
                                       Classes="muted"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />

                            <Grid Grid.Column="3"
                                  ColumnDefinitions="Auto,6,Auto">
                                <Button Grid.Column="0"
                                        x:Name="PreviousVideoButton"
                                        Classes="ghost"
                                        Content="Previous" />
                                <Button Grid.Column="2"
                                        x:Name="NextVideoButton"
                                        Classes="ghost"
                                        Content="Next" />
                            </Grid>
                        </Grid>
                    </Border>

                      <Grid Grid.Row="2"
                          RowDefinitions="*,*"
                          ColumnDefinitions="*,*">
                        <Border Grid.Row="0" Grid.Column="0"
                                Background="#070A0E">
                            <Panel>
                                <Image x:Name="PreviewBackgroundMaskImage" Stretch="Uniform" />
                                <Border VerticalAlignment="Top"
                                        Background="#99000000"
                                        Padding="8,5">
                                    <TextBlock Text="1. Background Estimation"
                                               Classes="cardTitle" />
                                </Border>
                            </Panel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1"
                                Background="#070A0E">
                            <Panel>
                                <Image x:Name="PreviewMovingColorImage" Stretch="Uniform" />
                                <Border VerticalAlignment="Top"
                                        Background="#99000000"
                                        Padding="8,5">
                                    <TextBlock Text="2. Moving Objects"
                                               Classes="cardTitle" />
                                </Border>
                            </Panel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0"
                                Background="#070A0E">
                            <Panel>
                                <Image x:Name="PreviewColorDetectionImage" Stretch="Uniform" />
                                <Border VerticalAlignment="Top"
                                        Background="#99000000"
                                        Padding="8,5">
                                    <TextBlock Text="3. Color Detection"
                                               Classes="cardTitle" />
                                </Border>
                            </Panel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1"
                                Background="#070A0E">
                            <Panel>
                                <Image x:Name="PreviewMotionImage" Stretch="Uniform" />
                                <Border VerticalAlignment="Top"
                                        Background="#99000000"
                                        Padding="8,5">
                                    <TextBlock Text="4. Speed + Direction"
                                               Classes="cardTitle" />
                                </Border>
                            </Panel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Expander Grid.Row="2"
                  IsExpanded="False"
                  Header="Runtime Log"
                  Margin="0,8,0,0"
                  FontWeight="SemiBold">
            <ListBox x:Name="LogListBox"
                     Height="170"
                     FontFamily="Cascadia Mono"
                     FontSize="12" />
        </Expander>
    </Grid>
</wnd:AppWindow>
