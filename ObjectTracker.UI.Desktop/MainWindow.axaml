<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ObjectTracker.UI.Desktop.MainWindow"
        Title="ObjectTracker - Background Estimation Lab"
        Width="1460"
        Height="900"
        MinWidth="1080"
        MinHeight="680"
        Background="#0B1217"
        d:DesignWidth="1460"
        d:DesignHeight="900">
    <Grid RowDefinitions="Auto,*,14,210" Margin="20">
        <Border Grid.Row="0"
                CornerRadius="14"
                Padding="20"
                Margin="0,0,0,16"
                BorderThickness="1"
                BorderBrush="#355562">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#15303D" />
                    <GradientStop Offset="1" Color="#244D5D" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="6">
                    <TextBlock Text="Background Estimation Lab"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#F2FBFF" />
                    <TextBlock Text="Fresh baseline: loop through videos and extract moving foreground using estimated static background."
                               Foreground="#C7E0E8"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Column="1"
                        VerticalAlignment="Center"
                        CornerRadius="999"
                        Padding="14,7"
                        Background="#17313A"
                        BorderThickness="1"
                        BorderBrush="#5E8A99">
                    <TextBlock x:Name="RunStateBadge"
                               Text="Idle"
                               Foreground="#E3F6FF"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="340,20,*">
            <Border Grid.Column="0"
                    CornerRadius="14"
                    Padding="16"
                    BorderThickness="1"
                    BorderBrush="#29414D"
                    Background="#101A20">
                <Grid RowDefinitions="Auto,14,Auto,14,*,16,Auto">
                    <StackPanel>
                        <TextBlock Text="Mock Cameras"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   Foreground="#E9F8FD" />
                        <TextBlock x:Name="PlaylistCountText"
                                   Text="0 cameras"
                                   Margin="0,4,0,0"
                                   Foreground="#98B7C2" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            CornerRadius="12"
                            Padding="12"
                            BorderThickness="1"
                            BorderBrush="#233B47"
                            Background="#0C1419">
                        <Grid RowDefinitions="*,12,Auto,10,Auto">
                            <ListBox Grid.Row="0"
                                     x:Name="PlaylistListBox"
                                     MinHeight="240" />

                            <Grid Grid.Row="2" ColumnDefinitions="*,10,*">
                                <Button x:Name="AddVideosButton"
                                        Grid.Column="0"
                                        Content="Add Mock Cameras"
                                        Height="40" />
                                <Button x:Name="RemoveSelectedButton"
                                        Grid.Column="2"
                                        Classes="destructive"
                                        Content="Remove Camera"
                                        Height="40" />
                            </Grid>

                            <Button Grid.Row="4"
                                    x:Name="ClearPlaylistButton"
                                    Classes="destructive"
                                    Content="Clear Cameras"
                                    Height="38" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            CornerRadius="12"
                            Padding="12"
                            BorderThickness="1"
                            BorderBrush="#233B47"
                            Background="#0C1419">
                        <Grid RowDefinitions="Auto,12,*,14,Auto">
                            <StackPanel>
                                <TextBlock Text="Processing Settings"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#DEF2F8" />
                                <TextBlock Text="Tune the background model and color motion filters for the selected camera."
                                           Margin="0,4,0,0"
                                           Foreground="#8FAEBA"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="12">
                                    <CheckBox x:Name="LoopPlaylistCheckBox"
                                              Content="Loop camera videos"
                                              IsChecked="True" />

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Samples"
                                                   Foreground="#CBE1E9"
                                                   FontWeight="SemiBold" />
                                        <TextBox x:Name="SampleCountTextBox"
                                                 Text="20"
                                                 Watermark="20"
                                                 HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Threshold"
                                                   Foreground="#CBE1E9"
                                                   FontWeight="SemiBold" />
                                        <TextBox x:Name="ThresholdTextBox"
                                                 Text="100"
                                                 Watermark="100"
                                                 HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Motion Area"
                                                   Foreground="#CBE1E9"
                                                   FontWeight="SemiBold" />
                                        <TextBox x:Name="MotionAreaTextBox"
                                                 Text="220"
                                                 Watermark="220"
                                                 HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Color Pixels"
                                                   Foreground="#CBE1E9"
                                                   FontWeight="SemiBold" />
                                        <TextBox x:Name="ColorMinPixelsTextBox"
                                                 Text="40"
                                                 Watermark="40"
                                                 HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Morph Kernel"
                                                   Foreground="#CBE1E9"
                                                   FontWeight="SemiBold" />
                                        <TextBox x:Name="MorphKernelSizeTextBox"
                                                 Text="3"
                                                 Watermark="3"
                                                 HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Process Width"
                                                   Foreground="#CBE1E9"
                                                   FontWeight="SemiBold" />
                                        <TextBox x:Name="ProcessWidthTextBox"
                                                 Text="640"
                                                 Watermark="640"
                                                 HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <StackPanel Grid.Row="4" Spacing="10">
                                <Button x:Name="StartStopButton"
                                        Classes="primary"
                                        Content="Start"
                                        Height="46"
                                        FontSize="16"
                                        FontWeight="Bold" />

                                <Button x:Name="OpenBakedMaskButton"
                                        Content="Open Baked Mask"
                                        Height="38" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="14"
                    Padding="12"
                    BorderThickness="1"
                    BorderBrush="#29414D"
                    Background="#0D151A">
                <Grid RowDefinitions="*,Auto,Auto,Auto">
                    <Border Grid.Row="0"
                            CornerRadius="10"
                            BorderThickness="1"
                            BorderBrush="#3C5562"
                            Background="#081014">
                        <Grid RowDefinitions="*,8,*" ColumnDefinitions="*,8,*" Margin="8">
                            <Border Grid.Row="0" Grid.Column="0" CornerRadius="8" BorderBrush="#34505C" BorderThickness="1" Background="#05090B">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="1. Background Estimation"
                                               Margin="8,6,8,4"
                                               Foreground="#CAE8F2"
                                               FontWeight="SemiBold" />
                                    <Image Grid.Row="1" x:Name="PreviewBackgroundMaskImage" Stretch="Uniform" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" CornerRadius="8" BorderBrush="#34505C" BorderThickness="1" Background="#05090B">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="2. Moving Objects (Color)"
                                               Margin="8,6,8,4"
                                               Foreground="#CAE8F2"
                                               FontWeight="SemiBold" />
                                    <Image Grid.Row="1" x:Name="PreviewMovingColorImage" Stretch="Uniform" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" CornerRadius="8" BorderBrush="#34505C" BorderThickness="1" Background="#05090B">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="3. Color Detection on Motion"
                                               Margin="8,6,8,4"
                                               Foreground="#CAE8F2"
                                               FontWeight="SemiBold" />
                                    <Image Grid.Row="1" x:Name="PreviewColorDetectionImage" Stretch="Uniform" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="2" CornerRadius="8" BorderBrush="#34505C" BorderThickness="1" Background="#05090B">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Text="4. Speed + Direction"
                                               Margin="8,6,8,4"
                                               Foreground="#CAE8F2"
                                               FontWeight="SemiBold" />
                                    <Image Grid.Row="1" x:Name="PreviewMotionImage" Stretch="Uniform" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,12,0,0" ColumnDefinitions="*,10,Auto,10,Auto">
                        <TextBlock Grid.Column="0"
                                   x:Name="CurrentVideoText"
                                   Text="Current camera/video: -"
                                   VerticalAlignment="Center"
                                   Foreground="#E3F4FA"
                                   FontWeight="SemiBold" />

                        <Button Grid.Column="2"
                                x:Name="PreviousVideoButton"
                                Content="Previous"
                                Height="36" />

                        <Button Grid.Column="4"
                                x:Name="NextVideoButton"
                                Content="Next"
                                Height="36" />
                    </Grid>

                    <TextBlock Grid.Row="2"
                               x:Name="StatusText"
                               Text="Status: ready"
                               Margin="0,10,0,0"
                               Foreground="#A6C2CC"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                CornerRadius="12"
                Padding="12"
                BorderThickness="1"
                BorderBrush="#29414D"
                Background="#0D161B">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Runtime Log"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#D3ECF5" />

                <ListBox Grid.Row="1"
                         x:Name="LogListBox"
                         Margin="0,10,0,0"
                         FontFamily="Cascadia Mono"
                         FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</Window>
