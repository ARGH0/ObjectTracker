<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ObjectTracker.UI.Desktop.MainWindow"
        Title="ObjectTracker"
        Width="960"
        Height="640"
        MinWidth="720"
        MinHeight="480"
        d:DesignWidth="960"
        d:DesignHeight="640">
    <Grid Background="#F3F1EC" ColumnDefinitions="2*,24,*" Margin="24">
        <Border Background="#FFFCF6"
                BorderBrush="#D9D3C6"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <Grid RowDefinitions="Auto,12,*">
                <TextBlock Text="Output Viewer"
                           FontSize="26"
                           FontWeight="SemiBold" />

                <Border Grid.Row="2"
                        Background="#ECE7DC"
                        BorderBrush="#D1C8B6"
                        BorderThickness="1"
                        CornerRadius="14"
                        ClipToBounds="True">
                    <Grid>
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform" />
                        <TextBlock x:Name="EmptyStateText"
                                   Text="Open an image or start the camera to run imported OpenCvSharp samples."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   Foreground="#6C6559" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Column="2" Spacing="14">
            <Border Background="#FFFDF8"
                    BorderBrush="#D9D3C6"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="ObjectTracker"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Avalonia ports of OpenCvSharp samples"
                               FontSize="16"
                               Foreground="#6C6559" />
                    <ComboBox x:Name="ProcessingModeComboBox" />
                    <TextBlock x:Name="SampleDescriptionText"
                               Text="Select a sample to see what it does."
                               TextWrapping="Wrap"
                               Foreground="#6C6559" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="OpenImageButton"
                                Content="Open image"
                                Height="40" />
                        <Button x:Name="OpenVideoButton"
                            Content="Open video"
                            Height="40" />
                        <Button x:Name="StartCameraButton"
                                Content="Start camera"
                                Height="40" />
                        <Button x:Name="StopCameraButton"
                            Content="Stop playback"
                                Height="40"
                                IsEnabled="False" />
                    </StackPanel>
                    <TextBlock Text="This is now a growing sample catalog. Use the camera for live-compatible samples or open a still image for one-off processing."
                               TextWrapping="Wrap"
                               Foreground="#6C6559" />
                    <TextBlock x:Name="StatusText"
                               Text="Load an image to begin."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Background="#FFFDF8"
                    BorderBrush="#D9D3C6"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="Sample output"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="ResultsListBox"
                             Height="260" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
