<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ObjectTracker.UI.Desktop.MainWindow"
        Title="CameraTrack"
        Width="1920"
        Height="1080"
        MinWidth="1280"
        MinHeight="720"
        d:DesignWidth="1920"
        d:DesignHeight="1080">
    <Grid ColumnDefinitions="1440,20,420" RowDefinitions="Auto,*" Margin="12">
        <Border Grid.RowSpan="2"
                Background="#111111"
                BorderBrush="#505050"
                BorderThickness="1"
                CornerRadius="6"
                Width="1440"
                Height="810"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
            <Grid>
                <TextBlock Text="Live Preview"
                           Foreground="#BFBFBF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <Image x:Name="PreviewImage"
                       Stretch="Uniform" />
            </Grid>
        </Border>

        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="12" Margin="0,20,0,0">
            <TextBlock Text="Bron" FontWeight="SemiBold" />
            <ComboBox x:Name="SourceComboBox"
                      HorizontalAlignment="Stretch"
                      SelectedIndex="0" />

            <TextBlock Text="Detector" FontWeight="SemiBold" Margin="0,8,0,0" />
            <ComboBox x:Name="DetectorComboBox"
                      HorizontalAlignment="Stretch"
                      SelectedIndex="0" />

            <Grid ColumnDefinitions="*,20,*" Margin="0,8,0,0">
                <Button x:Name="StartButton"
                        Grid.Column="0"
                        Content="Start"
                        Height="40" />
                <Button x:Name="StopButton"
                        Grid.Column="2"
                        Content="Stop"
                        Height="40" />
            </Grid>

            <TextBlock Text="Kleurfilter selector" FontWeight="SemiBold" Margin="0,8,0,0" />
            <Border BorderThickness="1" BorderBrush="#505050" CornerRadius="4" Padding="8">
                <ScrollViewer MaxHeight="120">
                    <StackPanel x:Name="ColorFilterPanel" Spacing="4" />
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="MetricsText"
                       Text="FPS: 0 | Proc: 0ms"
                       Margin="0,6,0,0" />

            <TextBlock x:Name="StatusText"
                       Text="Status: idle"
                       TextWrapping="Wrap"
                       MinHeight="40" />

            <TextBlock Text="Tracks" FontWeight="SemiBold" Margin="0,8,0,0" />
            <Border BorderThickness="1" BorderBrush="#505050" CornerRadius="4">
                <ListBox x:Name="TracksListBox"
                         Height="150" />
            </Border>
        </StackPanel>
    </Grid>
</Window>
